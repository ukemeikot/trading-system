# Forex data source: Twelve Data (optional — crypto runs without it).
# OANDA does not accept Nigerian accounts; since this system is paper-only, forex
# needs only a DATA feed, not a broker. Get a free key at https://twelvedata.com/
# (sign up -> API key). Free tier is rate-limited but fine for GBP/USD.
TWELVEDATA_API_KEY=

# Telegram notifications (optional; off by default via config flag)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
